# Investment Cockpit — Environment Variables
# Copy to .env.local and fill in your keys

# Claude API (REQUIRED) — console.anthropic.com
ANTHROPIC_API_KEY=

# Finnhub (REQUIRED) — finnhub.io/register
FINNHUB_API_KEY=

# Exa (REQUIRED) — exa.ai
EXA_API_KEY=

# Financial Modeling Prep (RECOMMENDED) — financialmodelingprep.com
FMP_API_KEY=

# Companies House UK (RECOMMENDED) — developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=

# SEC EDGAR — no key needed, just set your email as user agent
SEC_EDGAR_USER_AGENT=your-email@example.com

# DeepSeek V3 — deepseek.com/api — optional, ~10x cheaper for intermediate layers (earnings-research, market-research)
DEEPSEEK_API_KEY=

# SQLite local DB
DATABASE_URL=file:./prisma/dev.db
