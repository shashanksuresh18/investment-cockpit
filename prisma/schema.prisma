generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "sqlite"
}

model CockpitCache {
  id        String   @id
  companyId String   @unique
  data      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
